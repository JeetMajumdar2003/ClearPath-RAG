# ClearPath RAG Platform — Environment Variables (copy to .env and fill in; never commit .env)

# Application
APP_NAME=ClearPath RAG
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173

# PostgreSQL (app metadata — users, query logs, RAG config)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clearpath_app
POSTGRES_USER=clearpath
POSTGRES_PASSWORD=clearpath_dev_password

# Azure SQL Database (RAG data — clinical cases, embeddings, SPs)
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=ProjectClearPath
SQL_USERNAME=SQLAdmin
SQL_PASSWORD=your-sql-password
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_ENCRYPT=yes
SQL_TRUST_SERVER_CERTIFICATE=no

# Azure OpenAI (referenced by SQL stored procedures)
AZURE_OPENAI_RESOURCE_NAME=your-aoai-resource
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-aoai-api-key
AZURE_OPENAI_API_VERSION_EMBEDDINGS=2023-05-15
AZURE_OPENAI_API_VERSION_CHAT=2025-01-01-preview
AZURE_OPENAI_AUTH_METHOD=managed identity
AZURE_OPENAI_RBAC_ROLE=Cognitive Services OpenAI User
AZURE_OPENAI_PRICING_TIER=Standard S0
AZURE_OPENAI_CHAT_TARGET_URI=https://your-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview

# Database-scoped credential (used by SQL SPs to call Azure OpenAI)
DB_SCOPED_CREDENTIAL_NAME=https://your-resource.openai.azure.com
DB_SCOPED_CREDENTIAL_IDENTITY=Managed Identity
DB_SCOPED_CREDENTIAL_SECRET={"resourceid":"https://cognitiveservices.azure.com"}
SQL_MASTER_KEY_PASSWORD=change-me

# Embedding model — text-embedding-3-small
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_MODEL_DEPLOYMENT_NAME=text-embedding-3-small
EMBEDDING_MODEL_TARGET_URI=https://your-resource.openai.azure.com/openai/deployments/text-embedding-3-small/embeddings?api-version=2023-05-15
EMBEDDING_VECTOR_DIMENSIONS=1536
EMBEDDING_METRIC=cosine

# Chat model — GPT-4o
CHAT_MODEL_NAME=gpt-4o
CHAT_MODEL_DEPLOYMENT_NAME=gpt-4o
CHAT_MODEL_TEMPERATURE=0.2
CHAT_MODEL_MAX_TOKENS=800

# Azure SQL database objects
FULLTEXT_CATALOG_NAME=ClinicalCasesFTCatalog
CLINICAL_CASES_TABLE=dbo.ClinicalCases
CLINICAL_CASES_PRIMARY_KEY=PK_ClinicalCases
EMBEDDINGS_TABLE=dbo.ClinicalCaseEmbeddings
EXTERNAL_MODEL_NAME=embedding_openai_text3_small
EXTERNAL_MODEL_API_FORMAT=Azure OpenAI
EXTERNAL_MODEL_TYPE=EMBEDDINGS
VECTOR_INDEX_NAME=clinical_case_vector_index
VECTOR_METRIC=cosine

# Embedding types
EMBEDDING_TYPE_FULL_CASE=FullCase
EMBEDDING_TYPE_SYMPTOMS_ONLY=SymptomsOnly
EMBEDDING_TYPE_DIAGNOSIS_ONLY=DiagnosisOnly
EMBEDDING_TYPE_TREATMENT_ONLY=TreatmentOnly
EMBEDDING_TYPE_OUTCOME_ONLY=OutcomeOnly

# Stored procedures
SP_FIND_SIMILAR_CASES=dbo.usp_FindSimilarClinicalCases
SP_RRF_SEARCH=dbo.usp_RRFSearchClinicalCases
SP_RAG_SEARCH=dbo.usp_ClearPath_RAG_Search

# Azure portal URLs
AZURE_PORTAL_URL=https://portal.azure.com
FOUNDRY_PORTAL_URL=https://ai.azure.com
AZURE_REGION=eastus2

# RAG defaults
SEARCH_DEFAULT_TOP_N=5
RRF_VECTOR_WEIGHT=0.6
RRF_KEYWORD_WEIGHT=0.4
RRF_K=60
EMBEDDING_TYPE_DEFAULT=FullCase

# Admin seed (created on first run by python -m app.scripts.seed_admin)
ADMIN_EMAIL=admin@clearpath.local
ADMIN_PASSWORD=Admin123!
ADMIN_FULL_NAME=ClearPath Admin

# Frontend
VITE_API_URL=http://localhost:8000
