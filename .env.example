# ClearPath RAG Platform — Environment Variables (copy to .env and fill in; never commit .env)

# ============================================================================
# Application
# ============================================================================
APP_NAME=ClearPath RAG
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173

# ============================================================================
# PostgreSQL (app metadata — users, query logs, RAG config)
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clearpath_app
POSTGRES_USER=clearpath
POSTGRES_PASSWORD=clearpath_dev_password

# ============================================================================
# Clinical SQL Server — works for BOTH local SQL Server and Azure SQL.
# Only the address/credentials differ. AI_PROVIDER does NOT affect this.
# ============================================================================
# Local SQL Server (default — works on any dev machine)
SQL_SERVER=localhost
SQL_DATABASE=ProjectClearPath
SQL_USERNAME=sa
SQL_PASSWORD=YourStrong!Passw0rd
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_ENCRYPT=no
SQL_TRUST_SERVER_CERTIFICATE=yes
#
# Azure SQL (legacy / when AI_PROVIDER=azure)
# SQL_SERVER=your-server.database.windows.net
# SQL_DATABASE=ProjectClearPath
# SQL_USERNAME=SQLAdmin
# SQL_PASSWORD=your-sql-password
# SQL_ENCRYPT=yes
# SQL_TRUST_SERVER_CERTIFICATE=no

# Table names — defaults match the bundled SQL scripts.
CLINICAL_CASES_TABLE=dbo.ClinicalCases
CLINICAL_CASES_PRIMARY_KEY=PK_ClinicalCases
EMBEDDINGS_TABLE=dbo.ClinicalCaseEmbeddings
FULLTEXT_CATALOG_NAME=ClinicalCasesFTCatalog

# ============================================================================
# AI provider — pick ONE
# ============================================================================
#   openrouter    : Python pipeline, OpenRouter REST API  (default, free chat)
#   azure_python  : Python pipeline, Azure OpenAI REST API
#   azure         : legacy Azure SQL SPs (needs Azure SQL 2025)
# ============================================================================
AI_PROVIDER=openrouter

# ----- OpenRouter (default) -----------------------------------------------
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_EMBEDDING_DIMENSIONS=2048
OPENROUTER_CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_APP_NAME=ClearPath RAG
OPENROUTER_HTTP_REFERER=http://localhost:5173

# ----- Azure OpenAI (only required if AI_PROVIDER=azure or azure_python) --
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-aoai-api-key
AZURE_OPENAI_API_VERSION_EMBEDDINGS=2023-05-15
AZURE_OPENAI_API_VERSION_CHAT=2025-01-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# ----- Legacy Azure SQL SP names (only used when AI_PROVIDER=azure) -------
SP_FIND_SIMILAR_CASES=dbo.usp_FindSimilarClinicalCases
SP_RRF_SEARCH=dbo.usp_RRFSearchClinicalCases
SP_RAG_SEARCH=dbo.usp_ClearPath_RAG_Search

# ============================================================================
# RAG defaults
# ============================================================================
EMBEDDING_TYPE_DEFAULT=FullCase
EMBEDDING_VECTOR_DIMENSIONS=2048
SEARCH_DEFAULT_TOP_N=5
RRF_VECTOR_WEIGHT=0.6
RRF_KEYWORD_WEIGHT=0.4
RRF_K=60

# Embedding types the API exposes (matches the Azure SQL setup)
EMBEDDING_TYPE_FULL_CASE=FullCase
EMBEDDING_TYPE_SYMPTOMS_ONLY=SymptomsOnly
EMBEDDING_TYPE_DIAGNOSIS_ONLY=DiagnosisOnly
EMBEDDING_TYPE_TREATMENT_ONLY=TreatmentOnly
EMBEDDING_TYPE_OUTCOME_ONLY=OutcomeOnly

# ============================================================================
# Admin seed (created on first run by python -m app.scripts.seed_admin)
# ============================================================================
ADMIN_EMAIL=admin@clearpath.local
ADMIN_PASSWORD=Admin123!
ADMIN_FULL_NAME=ClearPath Admin

# ============================================================================
# Frontend
# ============================================================================
VITE_API_URL=http://localhost:8000
