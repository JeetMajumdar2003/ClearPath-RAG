# ClearPath RAG — root .gitignore
# Most rules are duplicated at the per-service level (backend/.gitignore,
# frontend/.gitignore). Keep them in sync if you change something here.

# ----------------------------------------------------------------------
# Secrets / env files
# ----------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.*
!.env.example
.envrc
lab/.env
lab/env.md
lab/sqlai.md

# ----------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
ENV/
.python-version.bak
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.cache/
.tox/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
*.cover
.ipynb_checkpoints/
*.pem

# ----------------------------------------------------------------------
# Node
# ----------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
out/
*.local
.vite/
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo
coverage/
.nyc_output/
*.lcov
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# npm / yarn / pnpm / lerna debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----------------------------------------------------------------------
# IDE / OS
# ----------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln

# ----------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------
postgres_data/
.docker/

# ----------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------------------
# Workshop materials — keep on disk, out of git
# ----------------------------------------------------------------------
lab/

# ----------------------------------------------------------------------
# Generated / dumped SQL output
# ----------------------------------------------------------------------
backend/app/scripts/sp_output*.txt